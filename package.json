{
	"name": "electrobun-vanilla-vite",
	"version": "1.0.0",
	"type": "module",
	"description": "Electrobun app with React, TypeScript and Vite HMR",
	"scripts": {
		"start": "vite build && electrobun dev",
		"dev": "electrobun dev --watch",
		"dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
		"hmr": "vite --port 5173",
		"build:canary": "vite build && electrobun build --env=canary",
		"lint": "eslint ."
	},
	"dependencies": {
		"@fontsource-variable/geist": "^5.2.8",
		"@fontsource-variable/jetbrains-mono": "^5.2.8",
		"@hookform/resolvers": "^5.2.2",
		"@phosphor-icons/react": "^2.1.10",
		"@tailwindcss/vite": "^4.2.1",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"electrobun": "1.15.1",
		"lucide-react": "^0.577.0",
		"next-themes": "^0.4.6",
		"radix-ui": "^1.4.3",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"shadcn": "^4.0.6",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4.2.1",
		"tw-animate-css": "^1.4.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@types/bun": "latest",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "4",
		"concurrently": "^9.1.0",
		"eslint": "^9.39.4",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.5.2",
		"globals": "^17.4.0",
		"typescript": "^5.7.2",
		"typescript-eslint": "^8.56.1",
		"vite": "^6.0.3"
	}
}
